{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile with role-based access status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "PROFESSOR", "STUDENT"] },
        "approved": { "type": "boolean" }
      },
      "required": ["uid", "email", "displayName", "role", "approved"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles containing information about approval status and roles"
    }
  }
}
